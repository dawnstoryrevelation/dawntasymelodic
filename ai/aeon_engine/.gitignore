# Python Bytecode and Cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual Environment (Crucial!)
.venv/

# IDE / Editor specific files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

