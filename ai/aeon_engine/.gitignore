# cognitive_atoms/atom_definitions/**/*.onnx
# cognitive_atoms/atom_definitions/**/*.pt
# cognitive_atoms/atom_definitions/**/*.joblib
# cognitive_atoms/atom_definitions/**/*.pkl

# OS generated files
.DS_Store
Thumbs.db

# OLI Reports (Generated output)
ooda_interface/reports/

# Compiled Blueprints Cache (If you implement caching)
# cognitive_blueprints/compiled_cache/